# Override files for local-only changes
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc
.terraform/
# 注意：.terraform.lock.hcl 應該進版控（鎖定 provider hash，CI/本機可重現），不要 ignore

# Plan output (may contain sensitive data)
*tfplan*
*.tfplan

